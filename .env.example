# ============================================================
#  genius-zone-dashboard — Environment Variables
# ============================================================

# REQUIRED — Anthropic API key for Claude analysis
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — Supabase (enables auth, quotas, persistence)
# Leave empty to run in auth-optional mode (localStorage only)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
